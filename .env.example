# WhatSignal Environment Variables
# Copy this file to .env and update with your actual values
#
# SECURE MODE (default): WhatSignal runs in secure mode unless WHATSIGNAL_ENV=development.
# In secure mode the variables marked "REQUIRED in secure mode" below MUST be set or the
# process refuses to start (e.g. "WHATSIGNAL_ADMIN_TOKEN is required in secure mode").
# Generate strong values with:  openssl rand -hex 32

# Environment. Leave unset (or anything other than "development") for secure mode.
# Set to "development" only for local testing to relax the secure-mode requirements.
# WHATSIGNAL_ENV=development

# WhatsApp API Key for WAHA (WhatsApp HTTP API)
# REQUIRED: Must match the API key configured in your WAHA instance
WHATSAPP_API_KEY=your-waha-api-key

# Webhook secret for WAHA (WhatsApp HTTP API)
# REQUIRED in secure mode (minimum 32 characters). This is the only place to set it.
WHATSIGNAL_WHATSAPP_WEBHOOK_SECRET=your-very-secure-whatsapp-webhook-secret

# Admin token, gates diagnostics endpoints (/metrics and /session/status).
# REQUIRED in secure mode (minimum 32 characters). Send as: Authorization: Bearer <token>
WHATSIGNAL_ADMIN_TOKEN=your-very-secure-admin-token

# WhatSignal image to deploy. Use :latest for stable releases, :main for
# the newest main branch build, or a specific version tag such as :1.2.49.
WHATSIGNAL_IMAGE=ghcr.io/bikemazzell/whatsignal:latest

# Encryption Configuration
# Enable encryption for sensitive data in the database
WHATSIGNAL_ENABLE_ENCRYPTION=true
# Secret for encrypting sensitive database fields.
# REQUIRED when encryption is enabled (minimum 32 characters).
WHATSIGNAL_ENCRYPTION_SECRET=your-very-secure-encryption-secret-change-this
# Unique salts for encryption key derivation.
# REQUIRED in secure mode (minimum 16 characters each).
# NOTE: changing a salt re-derives the key and makes previously-encrypted data
# unreadable. Upgrading from < 1.2.52 and never set these before? You were using
# the built-in defaults; set them to whatsignal-salt-v1 / whatsignal-lookup-salt-v1
# to keep existing data, then rotate to random values only if you can reset the cache.
WHATSIGNAL_ENCRYPTION_SALT=your-unique-encryption-salt
WHATSIGNAL_ENCRYPTION_LOOKUP_SALT=your-unique-lookup-salt

# Optional: Override other configuration values
# WHATSAPP_API_URL=http://waha:3000
# SIGNAL_RPC_URL=http://signal-cli:8080
# DB_PATH=/app/data/whatsignal.db
# MEDIA_DIR=/app/cache
